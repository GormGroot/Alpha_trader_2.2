# ═══════════════════════════════════════════════════════════
#  Alpha Trading Platform — Environment Variables
# ═══════════════════════════════════════════════════════════
#  Kopiér til .env og udfyld med rigtige værdier:
#    cp .env.example .env
#
#  VIGTIGT: .env må ALDRIG committes til git!
# ═══════════════════════════════════════════════════════════

# --- Alpaca (US + Crypto) ------------------------------------
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets

# --- Saxo Bank (EU ETFs, Bonds) ------------------------------
SAXO_APP_KEY=your_saxo_app_key
SAXO_APP_SECRET=your_saxo_app_secret
SAXO_REDIRECT_URI=http://localhost:8080/callback
# Environment: sim | live (styres via --paper flag)

# --- Interactive Brokers (EU, Commodities, Forex, Options) ----
IBKR_ENABLED=false
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
# Ports: 7497=TWS paper, 7496=TWS live, 4002=Gateway paper, 4001=Gateway live
IBKR_CLIENT_ID=1

# --- Nordnet (Nordic Stocks, DK Fonde) -----------------------
NORDNET_USER=your_nordnet_username
NORDNET_PASS=your_nordnet_password
NORDNET_COUNTRY=dk
# Country: dk | se | no | fi

# --- PostgreSQL -----------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=alpha_trader
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=alpha_trader

# --- Redis (optional, for caching) ----------------------------
REDIS_URL=redis://localhost:6379/0

# --- Email Reports --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your_email@gmail.com
REPORT_EMAIL_TO=your_report_recipient@example.com

# --- Claude API (AI Analysis) --------------------------------
ANTHROPIC_API_KEY=your_claude_api_key
CLAUDE_DAILY_BUDGET=3.00
CLAUDE_MONTHLY_BUDGET=50.00

# --- Alpha Vantage (optional, extra market data) --------------
MARKET_DATA_ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# --- News API (optional) -------------------------------------
NEWS_API_KEY=your_newsapi_key

# --- Dashboard ------------------------------------------------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050

# --- Logging --------------------------------------------------
LOG_LEVEL=DEBUG

# --- Backup ---------------------------------------------------
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30

# --- Mobile App / API (port 8051) ----------------------------
APP_USERNAME=ole
APP_PASSWORD=your_strong_password_here
APP_SECRET_KEY=generate_with_python_-c_secrets.token_hex_32
APP_TOKEN_TTL_MINUTES=30   # Auto-logout efter 30 min inaktivitet (15-1440)

# --- Telegram (2FA + notifikationer) -------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather
TELEGRAM_CHAT_ID=your_personal_chat_id

# --- Geo-lock (login-beskyttelse) ----------------------------
GEO_LOCK_ENABLED=true             # false for at slå fra
GEO_LOCK_COUNTRIES=DK             # ISO-koder, komma-separeret (DK,SE,NO)
GEO_LOCK_BYPASS=                  # 32+ tegn hemmelig kode til rejser (lad tom for at deaktivere)
